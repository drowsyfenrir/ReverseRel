  "labels": [
    {
      "id": "l-1779981234936",
      "text": "성 파블로프 재단",
      "x": 1009,
      "y": 306,
      "w": 400,
      "h": 44,
      "name": "성 파블로프 재단",
      "description": "마도학자들이 인류와의 공존을 위해 설립한 자선 단체다.\n재단 본부는 폭풍우의 영향을 받지 않는다."
    },
    {
      "id": "l-1779996528607",
      "name": "팍스 하우스",
      "description": "세계관 내 최고 기관,\n팍스 하우스 (Pax House), 하얀 벽돌집(White Marble House), 인류 평화 안전 보장 이사회, 비둘기집 등으로 불린다.\n파블로프 재단, 라플라스 연구소, 제노군보다 더 위로 보인다.",
      "x": 859,
      "y": 48,
      "w": 700,
      "h": 80
    },
    {
      "id": "l-1780002729561",
      "name": "행정부",
      "description": "현장 파견 요원(Field Agent)이 소속된 부서. 의회제 형태인지 위원회 의원들이 자기 휘하에 조사원들을 거느리고 있다.",
      "x": 859,
      "y": 474,
      "w": 700,
      "h": 40
    }
  ]
}