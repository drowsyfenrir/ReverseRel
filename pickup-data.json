        {
          "id": "block-1783941463173-c526e47adef9a",
          "type": "banner",
          "text": "",
          "banner": "3.8 호수의 물결",
          "name": "",
          "kind": "",
          "category": "호수의 물결 :",
          "content": "마도학자 선택 후 70번 안으로 확정 픽업",
          "note": "이월 가능, J 추천",
          "names": [],
